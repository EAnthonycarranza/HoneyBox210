{
  "name": "honeybox210",
  "version": "1.0.0",
  "description": "Honey Box 210 - Fresh Honey from San Antonio, TX",
  "scripts": {
    "server": "cd server && node server.js",
    "client": "cd client && npm start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "cd server && npm install && cd ../client && npm install",
    "seed": "cd server && node -e \"require('./config/db')().then(() => require('./routes/products').seedProducts())\""
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
